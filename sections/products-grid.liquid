{% liquid
  assign products_per_page = section.settings.products_per_page | default: 12
  assign collection = collections[section.settings.collection] | default: collections.all
%}

<div class="products-grid full-width" id="products-grid-{{ section.id }}">
  <div class="products-grid__container">
    {% if section.settings.show_heading %}
      <h2 class="products-grid__heading">{{ section.settings.heading | default: collection.title }}</h2>
    {% endif %}

    {% paginate collection.products by products_per_page %}
      <div class="products-grid__items" id="products-list-{{ section.id }}">
        {% for product in collection.products %}
          <div class="products-grid__item">
            <div class="product-card__window">
              <div class="product-card__title-bar">
                <div class="product-card__title-bar-title">
                  <span class="product-card__title-bar-icon" aria-hidden="true"></span>
                  <span class="product-card__title-bar-text">{{ 'general.window_title' | t | default: 'Raviolli Press' }}</span>
                </div>
                <div class="product-card__title-bar-controls">
                  <button class="product-card__control">_</button>
                  <button class="product-card__control">□</button>
                  <button class="product-card__control">×</button>
                </div>
              </div>

              <div class="product-card__content">
                <div class="product-card__image-wrapper">
                  {% if product.featured_image %}
                    <a href="{{ product.url }}">
                      {{ product.featured_image | image_url: width: 400 | image_tag: class: 'product-card__image', loading: 'lazy' }}
                    </a>
                  {% else %}
                    <div class="product-card__placeholder">
                      {{ 'product-1' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </div>

                <div class="product-card__info">
                  <h3 class="product-card__name">
                    <a href="{{ product.url }}">{{ product.title }}</a>
                  </h3>

                  <div class="product-card__price">
                    {% if product.compare_at_price > product.price %}
                      <span class="product-card__price--sale">{{ product.price | money }}</span>
                      <span class="product-card__price--compare">{{ product.compare_at_price | money }}</span>
                    {% else %}
                      <span>{{ product.price | money }}</span>
                    {% endif %}
                  </div>

                  <a href="{{ product.url }}" class="product-card__button">
                    {{ 'products.view_details' | t | default: 'View details' }}
                  </a>
                </div>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>

      {% if paginate.next %}
        <div class="products-grid__loader" id="loader-{{ section.id }}">
          <div class="products-grid__loader-spinner"></div>
        </div>
        <div
          class="products-grid__next-url"
          data-next-url="{{ paginate.next.url }}"
          style="display: none;"></div>
      {% endif %}
    {% endpaginate %}
  </div>
</div>

{% stylesheet %}
  .products-grid {
    padding: 2rem 0;
    min-height: 100vh;
  }

  .products-grid__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 var(--page-margin);
  }

  .products-grid__heading {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 2rem;
    text-align: center;
  }

  .products-grid__items {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
  }

  .products-grid__item {
    animation: fadeInUp 0.5s ease-out forwards;
    opacity: 0;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .products-grid__loader {
    display: flex;
    justify-content: center;
    padding: 3rem 0;
  }

  .products-grid__loader-spinner {
    width: 50px;
    height: 50px;
    border: 4px solid rgba(255, 255, 255, 0.2);
    border-top-color: var(--color-foreground);
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  .product-card__window {
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-radius: 8px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1)
    , inset 0 1px 0 rgba(255, 255, 255, 0.4)
    , inset 0 -1px 0 rgba(0, 0, 0, 0.1);
    overflow: hidden;
    transition: transform 0.2s ease
    , box-shadow 0.2s ease;
    height: 100%;
  }

  .product-card__window:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.15)
    , inset 0 1px 0 rgba(255, 255, 255, 0.4)
    , inset 0 -1px 0 rgba(0, 0, 0, 0.1);
  }

  .product-card__title-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 30px;
    padding: 0 0.75rem;
    background: rgba(0, 0, 0, 0.6);
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    margin-top: -1px;
    /* overlap the inner highlight line */
  }

  .product-card__title-bar-text {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-foreground);
  }

  .product-card__title-bar-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex: 1 1 auto;
    height: 100%;
    color: #ffffff;
  }

  .product-card__title-bar-icon {
    width: 14px;
    height: 14px;
    border: 1px solid rgba(0, 0, 0, 0.25);
    border-radius: 2px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 1) 0%, rgba(255, 255, 255, 0.9) 100%);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.6)
    , inset 0 -1px 0 rgba(0, 0, 0, 0.08);
  }

  .product-card__title-bar-controls .product-card__control:last-child {
    background: #e74c3c;
    border-color: rgba(231, 76, 60, 0.8);
    color: #ffffff;
  }

  .product-card__title-bar-controls .product-card__control:last-child:hover {
    background: #ff6b57;
    border-color: rgba(231, 76, 60, 0.9);
  }

  .product-card__title-bar-controls {
    display: flex;
    gap: 0.25rem;
  }

  .product-card__control {
    width: 20px;
    height: 20px;
    border: 1px solid rgba(0, 0, 0, 0.2);
    background: rgba(255, 255, 255, 0.3);
    border-radius: 2px;
    cursor: pointer;
    font-size: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease;
  }

  .product-card__control:hover {
    background: rgba(255, 255, 255, 0.5);
  }

  .product-card__content {
    padding: 1rem;
  }

  .product-card__image-wrapper {
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.1);
    margin-bottom: 1rem;
  }

  .product-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .product-card__window:hover .product-card__image {
    transform: scale(1.05);
  }

  .product-card__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.3);
  }

  .product-card__placeholder svg {
    width: 50%;
    height: 50%;
  }

  .product-card__info {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .product-card__name {
    font-size: 1rem;
    font-weight: 600;
    margin: 0;
  }

  .product-card__name a {
    color: var(--color-foreground);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .product-card__name a:hover {
    opacity: 0.7;
  }

  .product-card__price {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
  }

  .product-card__price--sale {
    color: #e74c3c;
  }

  .product-card__price--compare {
    text-decoration: line-through;
    color: rgba(0, 0, 0, 0.4);
    font-size: 0.875rem;
  }

  .product-card__button {
    display: inline-block;
    padding: 0.625rem 1.25rem;
    background: rgba(255, 255, 255, 0.25);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 4px;
    color: var(--color-foreground);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.875rem;
    transition: all 0.2s ease;
    text-align: center;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.3);
  }

  .product-card__button:hover {
    background: rgba(255, 255, 255, 0.35);
    border-color: rgba(255, 255, 255, 0.4);
    transform: translateY(-1px);
  }

  @media (max-width: 1024px) {
    .products-grid__items {
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 1.5rem;
    }
  }

  @media (max-width: 768px) {
    .products-grid {
      padding: 1.5rem 0;
    }

    .products-grid__heading {
      font-size: 2rem;
      margin-bottom: 1.5rem;
    }

    .products-grid__items {
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      gap: 1rem;
    }

    .product-card__title-bar-text {
      font-size: 0.75rem;
    }

    .product-card__content {
      padding: 0.75rem;
    }

    .product-card__name {
      font-size: 0.875rem;
    }

    .product-card__button {
      font-size: 0.8125rem;
      padding: 0.5rem 1rem;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function() {
    const grids = document.querySelectorAll('.products-grid');
    grids.forEach((grid) => {
      const idMatch = grid.id && grid.id.match(/^products-grid-(.+)$/);
      const sectionId = idMatch
        ? idMatch[1]
        : null;
      if (! sectionId) return;
      


      const productsList = grid.querySelector(`#products-list-${sectionId}`);
      const loader = grid.querySelector(`#loader-${sectionId}`);
      const nextUrlElement = grid.querySelector('.products-grid__next-url');

      if (! nextUrlElement) return;
      


      let loading = false;
      let nextUrl = nextUrlElement.getAttribute('data-next-url');

      function loadMoreProducts() {
        if (loading || ! nextUrl) return;
        


        loading = true;
        if (loader) 
          loader.style.display = 'flex';
        


        fetch(nextUrl).then(response => response.text()).then(html => {
          const parser = new DOMParser();
          const doc = parser.parseFromString(html, 'text/html');

          const newProducts = doc.querySelectorAll(`#products-list-${sectionId} .products-grid__item`);
          newProducts.forEach((product, index) => {
            product.style.animationDelay = `${
              index * 0.05
            }s`;
            productsList.appendChild(product);
          });

          const newNextUrlElement = doc.querySelector(`#products-grid-${sectionId} .products-grid__next-url`);
          if (newNextUrlElement) {
            nextUrl = newNextUrlElement.getAttribute('data-next-url');
          } else {
            nextUrl = null;
            if (loader) 
              loader.style.display = 'none';
            


          } loading = false;
        }).catch(error => {
          console.error('Error loading more products:', error);
          loading = false;
          if (loader) 
            loader.style.display = 'none';
          


        });
      }

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            loadMoreProducts();
          }
        });
      }, {rootMargin: '200px'});

      if (loader) {
        observer.observe(loader);
      }
    });
  })();
{% endjavascript %}

{% schema %}
  {
    "name": "t:general.products_grid",
    "settings": [
      {
        "type": "collection",
        "id": "collection",
        "label": "t:labels.collection",
        "info": "t:info.collection"
      }, {
        "type": "checkbox",
        "id": "show_heading",
        "label": "t:labels.show_heading",
        "default": true
      }, {
        "type": "text",
        "id": "heading",
        "label": "t:labels.heading",
        "default": "Our products"
      }, {
        "type": "range",
        "id": "products_per_page",
        "label": "t:labels.products_per_page",
        "min": 8,
        "max": 48,
        "step": 4,
        "default": 12
      }
    ],
    "presets": [
      {
        "name": "t:general.products_grid",
        "category": "t:general.products"
      }
    ]
  }
{% endschema %}
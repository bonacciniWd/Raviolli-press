<div class="customer-login" style="background-image: url({{ 'login-bg.webp' | asset_url }}); background-size: cover; background-position: center;">
  <div class="customer-login__container">
    <div class="customer-login__form-wrapper">
      <h1>{{ 'customers.login.title' | t }}</h1>
      <div class="customer-login__logo">
        <img
          src="{{ 'logo.png' | asset_url }}"
          alt="{{ shop.name }}"
          width="96"
          height="96" />
      </div>

      {% form 'customer_login' %}
        {% if form.errors %}
          <div class="form-errors">
            {{ form.errors | default_errors }}
          </div>
        {% endif %}

        <div class="form-group">
          <label for="customer-email">{{ 'customers.login.email' | t }}</label>
          <input
            type="email"
            id="customer-email"
            name="customer[email]"
            autocomplete="email"
            required>
        </div>

        <div class="form-group">
          <label for="customer-password">{{ 'customers.login.password' | t }}</label>
          <input
            type="password"
            id="customer-password"
            name="customer[password]"
            autocomplete="current-password"
            required>
        </div>

        <div class="form-actions">
          <button type="submit" class="button button--primary">
            {{ 'customers.login.submit' | t }}
          </button>
          <a href="{{ routes.account_recover_url }}">
            {{ 'customers.login.forgot_password' | t | default: 'Forgot your password?' }}
          </a>
        </div>
      {% endform %}

      <div class="customer-login__register">
        <p>{{ 'customers.login.new_customer' | t | default: 'New customer?' }}</p>
        <a href="{{ routes.account_register_url }}" class="button button--secondary">
          {{ 'customers.login.create_account' | t | default: 'Create account' }}
        </a>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .customer-login {
    padding: 3rem 0;
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .customer-login__container {
    max-width: 500px;
    width: 100%;
    padding: 0 var(--page-margin);
  }

  .customer-login__form-wrapper {
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(10px);
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-radius: 8px;
    padding: 2.5rem;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
  }

  .customer-login__logo {
    display: flex;
    justify-content: center;
    margin-bottom: 1rem;
  }
  .customer-login__logo img {
    width: 96px;
    height: auto;
  }

  .customer-login h1 {
    font-size: 2rem;
    margin-bottom: 2rem;
    text-align: center;
  }

  .form-errors {
    background: rgba(231, 76, 60, 0.1);
    border: 1px solid rgba(231, 76, 60, 0.3);
    border-radius: 4px;
    padding: 1rem;
    margin-bottom: 1.5rem;
    color: #e74c3c;
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  .form-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 500;
  }

  .form-group input {
    width: 100%;
    padding: 0.75rem;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 4px;
    color: var(--color-foreground);
    font-size: 1rem;
  }

  .form-group input:focus {
    outline: none;
    border-color: rgba(255, 255, 255, 0.4);
    background: rgba(255, 255, 255, 0.15);
  }

  .form-actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 2rem;
  }

  .form-actions a {
    text-align: center;
    color: var(--color-foreground);
    text-decoration: underline;
    font-size: 0.875rem;
  }

  .button {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background: rgba(255, 255, 255, 0.25);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 4px;
    color: var(--color-foreground);
    text-decoration: none;
    font-weight: 500;
    transition: all 0.2s ease;
    text-align: center;
    cursor: pointer;
    font-size: 1rem;
  }

  .button:hover {
    background: rgba(255, 255, 255, 0.35);
  }

  .button--primary {
    background: rgba(255, 255, 255, 0.3);
  }

  .button--secondary {
    background: rgba(0, 0, 0, 0.1);
    border-color: rgba(0, 0, 0, 0.2);
  }

  .customer-login__register {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    text-align: center;
  }

  .customer-login__register p {
    margin-bottom: 1rem;
  }

  @media (max-width: 768px) {
    .customer-login__form-wrapper {
      padding: 2rem 1.5rem;
    }

    .customer-login h1 {
      font-size: 1.5rem;
    }
  }
{% endstylesheet %}

{% schema %}
  {
    "name": "Customer login",
    "settings": []
  }
{% endschema %}
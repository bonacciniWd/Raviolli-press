{% comment %}
  Product page with responsive layout and a simple image carousel.
{% endcomment %}

<div class="product">
  <div class="product__gallery">
    <div class="product__carousel">
      <div class="product__slides">
        {% for image in product.images %}
          <div class="product__slide{% if forloop.first %} is-active{% endif %}">
            {% render 'image'
              , class: 'product__slide-image'
              , image: image %}
          </div>
        {% endfor %}
      </div>
      <button class="product__nav product__nav--prev" aria-label="Previous">‹</button>
      <button class="product__nav product__nav--next" aria-label="Next">›</button>
      <div class="product__dots">
        {% for image in product.images %}
          <button
            class="product__dot{% if forloop.first %} is-active{% endif %}"
            data-index="{{ forloop.index0 }}"
            aria-label="Go to slide {{ forloop.index }}"></button>
        {% endfor %}
      </div>
    </div>
  </div>

  <div class="product__info">
    <h1 class="product__title">{{ product.title }}</h1>
    <p class="product__price">{{ product.price | money }}</p>
    <div class="product__description">{{ product.description }}</div>

    <div class="product-form">
      {% form 'product'
        , product %}
        {% assign current_variant = product.selected_or_first_available_variant %}

        <label class="visually-hidden" for="product-variant">Variant</label>
        <select
          id="product-variant"
          name="id"
          class="product-form__select">
          {% for variant in product.variants %}
            <option
              value="{{ variant.id }}"
              {% if variant == current_variant %}
              selected="selected"
              {% endif %}>
              {{ variant.title }} - {{ variant.price | money }}
            </option>
          {% endfor %}
        </select>

        <div class="product-form__row">
          <label class="visually-hidden" for="product-quantity">Quantity</label>
          <input
            id="product-quantity"
            class="product-form__qty"
            type="number"
            name="quantity"
            min="1"
            value="1">
          <input
            class="product-form__submit"
            type="submit"
            value="Add to cart">
        </div>

        <div class="product-form__express">
          {{ form | payment_button }}
        </div>
      {% endform %}
    </div>
  </div>
</div>

{% stylesheet %}
  .product {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 2rem;
    align-items: start;
  }

  .product__gallery {
    position: relative;
  }

  .product__carousel {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: 8px;
    height: min(70vh, 800px);
  }

  .product__slides {
    display: flex;
    width: 100%;
    transform: translateX(0%);
    transition: transform 0.3s ease;
    height: 100%;
    touch-action: pan-y;
    -webkit-user-select: none;
    user-select: none;
  }

  .product__slide {
    min-width: 100%;
    height: 100%;
  }

  .product__slide-image {
    height: 100%;
  }

  .product__slide-image > img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .product__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 36px;
    height: 36px;
    border-radius: 18px;
    border: 1px solid rgba(0, 0, 0, 0.2);
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(6px);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .product__nav--prev {
    left: 8px;
  }
  .product__nav--next {
    right: 8px;
  }

  .product__dots {
    display: flex;
    gap: 6px;
    justify-content: center;
    margin-top: 10px;
  }

  .product__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.25);
    border: 0;
    cursor: pointer;
  }

  .product__dot.is-active {
    background: rgba(0, 0, 0, 0.6);
  }

  .product__title {
    font-size: 2rem;
    margin: 0 0 0.5rem;
  }

  .product__price {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .product__description {
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }

  .product-form__select,
  .product-form__qty {
    border: 1px solid rgba(0, 0, 0, 0.2);
    background: rgba(255, 255, 255, 0.6);
    padding: 0.65rem 0.75rem;
    border-radius: 4px;
  }

  .product-form__row {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    margin-top: 0.75rem;
  }

  .product-form__submit {
    padding: 0.65rem 1.25rem;
    background: rgba(0, 0, 0, 0.8);
    color: #fff;
    border: 1px solid rgba(0, 0, 0, 0.9);
    border-radius: 4px;
    cursor: pointer;
  }

  .product-form__express {
    margin-top: 0.75rem;
  }

  .visually-hidden {
    position: absolute !important;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 1024px) {
    .product {
      grid-template-columns: 1fr;
    }

    .product__title {
      font-size: 1.75rem;
    }
    .product__carousel {
      height: min(60vh, 600px);
    }
  }

  @media (max-width: 768px) {
    .product__carousel {
      border-radius: 6px;
      height: min(50vh, 520px);
    }
    .product-form__row {
      gap: 0.75rem;
    }
    .product-form__select,
    .product-form__qty {
      width: 100%;
    }
    .product-form__row {
      flex-wrap: wrap;
    }
    .product-form__submit {
      width: 100%;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function() {
    const galleries = document.querySelectorAll('.product__gallery');
    galleries.forEach((gallery) => {
        const slidesContainer = gallery.querySelector('.product__slides');
        const slides = gallery.querySelectorAll('.product__slide');
        const dots = gallery.querySelectorAll('.product__dot');
        const prev = gallery.querySelector('.product__nav--prev');
        const next = gallery.querySelector('.product__nav--next');

        if (! slidesContainer || slides.length === 0) return;
        


        let index = 0;

        function update() {
          slidesContainer.style.transform = 'translateX(' + (- index * 100) + '%)';
          dots.forEach((d, i) => d.classList.toggle('is-active', i === index));
        }

        function goTo(i) {
          index = (i + slides.length) % slides.length;
          update();
        }

        if (prev) 
          prev.addEventListener('click', () => goTo(index - 1));
        


        if (next) 
          next.addEventListener('click', () => goTo(index + 1));
        


        dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

  // Swipe support (touch/mobile only)
        let startX = 0;
        let isDown = false;
        let startPercent = 0;

        function setTransition(enabled) {
          slidesContainer.style.transition = enabled
            ? 'transform 0.3s ease'
            : 'none';
        }
        const enableDrag = window.matchMedia('(pointer: coarse)').matches || window.innerWidth<= 1024;
      if (enableDrag) {
        slidesContainer.addEventListener('pointerdown', (e) => {
          isDown = true;
          startX = e.clientX;
          startPercent = - index * 100;
          setTransition(false);
        }
      );

      slidesContainer.addEventListener('pointermove', (e) => {
        if (! isDown) return;
        
        const dx = e.clientX - startX;
        const deltaPercent = (dx / slidesContainer.clientWidth) * 100;
        let nextPercent = startPercent + deltaPercent;
        const minPercent = -(slides.length - 1) * 100;
        if (nextPercent > 0) 
          nextPercent = 0;
        
        if (nextPercent < minPercent) 
          nextPercent = minPercent;
        
        slidesContainer.style.transform = 'translateX(' + nextPercent + '%)';
      });

      window.addEventListener('pointerup', (e) => {
        if (! isDown) return;
        
        isDown = false;
        const dx = e.clientX - startX;
        if (Math.abs(dx) > 40) {
          if (dx < 0) 
            goTo(index + 1);
           else 
            goTo(index - 1);
          
        }
        setTransition(true);
        update();
      });
    }

    update();
  });
})();
{% endjavascript %}

{% schema %}
  {
    "name": "t:general.product",
    "settings": [],
    "disabled_on": {
      "groups": ["header", "footer"]
    }
  }
{% endschema %}